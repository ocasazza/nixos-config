+def _build_vertex_proxy_client(base_url: str, kwargs: dict):
+    """Build an Anthropic client for a Vertex AI proxy.
+
+    Rewrites Anthropic Messages API requests to Vertex AI rawPredict format,
+    transforms request bodies, and authenticates with gcloud identity tokens.
+    """
+    import httpx
+    import subprocess as _sp
+
+    project_id = os.environ.get("ANTHROPIC_VERTEX_PROJECT_ID", "")
+    region = os.environ.get("CLOUD_ML_REGION", "us-east5")
+
+    if not project_id:
+        raise ValueError(
+            "ANTHROPIC_VERTEX_PROJECT_ID environment variable is required "
+            "when using a Vertex AI proxy (detected 'vertex' in base_url)"
+        )
+
+    class VertexProxyTransport(httpx.BaseTransport):
+        """Rewrites requests for Vertex AI rawPredict format."""
+
+        def __init__(self):
+            self._transport = httpx.HTTPTransport()
+
+        def handle_request(self, request: httpx.Request) -> httpx.Response:
+            url = str(request.url)
+
+            # Get fresh gcloud identity token for each request
+            try:
+                result = _sp.run(
+                    ["gcloud", "auth", "print-identity-token"],
+                    capture_output=True, text=True, timeout=10,
+                )
+                id_token = result.stdout.strip()
+                if not id_token:
+                    raise RuntimeError("gcloud returned empty identity token")
+            except Exception as e:
+                logger.error("Failed to get gcloud identity token: %s", e)
+                raise
+
+            # Transform body: extract model for URL, add anthropic_version
+            vertex_model = "claude-sonnet-4-5"
+            body_bytes = request.content
+            if body_bytes:
+                try:
+                    body = json.loads(body_bytes)
+                    if "model" in body:
+                        vertex_model = body.pop("model")
+                    body["anthropic_version"] = "vertex-2023-10-16"
+                    body_bytes = json.dumps(body).encode()
+                except (json.JSONDecodeError, ValueError) as e:
+                    logger.error("Failed to transform request body: %s", e)
+
+            # Rewrite URL: /v1/messages → Vertex rawPredict path
+            if "/v1/messages" in url:
+                url = url.replace(
+                    "/v1/messages",
+                    f"/v1/projects/{project_id}/locations/{region}"
+                    f"/publishers/anthropic/models/{vertex_model}:streamRawPredict",
+                    1,
+                )
+                logger.info("Rewrote URL for Vertex AI: %s", url)
+
+            # Set auth and project headers; drop stale Content-Length (httpx recomputes it)
+            headers = dict(request.headers)
+            headers["authorization"] = f"Bearer {id_token}"
+            headers["x-goog-user-project"] = project_id
+            headers.pop("x-api-key", None)
+            headers.pop("content-length", None)
+
+            new_request = httpx.Request(
+                method=request.method, url=url,
+                headers=headers, content=body_bytes,
+            )
+            return self._transport.handle_request(new_request)
+
+        def close(self):
+            self._transport.close()
+
+    http_client = httpx.Client(transport=VertexProxyTransport())
+    kwargs["api_key"] = "vertex-proxy-placeholder"
+    kwargs["http_client"] = http_client
+    if _COMMON_BETAS:
+        kwargs["default_headers"] = {"anthropic-beta": ",".join(_COMMON_BETAS)}
+    return _anthropic_sdk.Anthropic(**kwargs)
+
