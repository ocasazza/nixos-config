{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Custom panels for the luna AI stack — covers vault ingestion, opencode workload, vLLM serving, GPU thermals, and cross-cutting cost. Pair with the claude-code dashboard for cost/token/session views.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Vault ingestion health",
      "type": "row"
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Time since last reingest run",
      "description": "Hourly cadence (launchd). Red >75min = launchd or flock broke silently.",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "time() - reingest_last_run_timestamp_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3900 },
              { "color": "red", "value": 4500 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Reingest candidate backlog",
      "description": "Persistent non-zero = /reingest is failing to swap ingest/auto -> ingest/done; same notes burn cost every hour.",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "reingest_candidates_total",
          "legendFormat": "candidates",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Reingest success rate (24h)",
      "description": "Hourly gauge sampled with [24h:1h] subquery. 1.0 = every run in last 24h returned exit 0.",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "1 - (sum_over_time((reingest_last_exit_code > bool 0)[24h:1h]) / 24)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "state-timeline",
      "title": "Reingest run timeline",
      "description": "State per hourly tick. Gaps = missed runs (launchd off / lock stuck), red = exit != 0.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "reingest_last_exit_code",
          "legendFormat": "rc",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 101,
      "panels": [],
      "title": "opencode workload",
      "type": "row"
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Cost burn rate ($/hour)",
      "description": "rate() not irate() — exporter polls SQLite on an interval, so irate spikes artificially on every scrape.",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(opencode_cost_usd_total[1h])) * 3600",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Cost by project (24h)",
      "description": "Top 5 path.cwd by 24h cost. Watch for runaway projects.",
      "gridPos": { "h": 6, "w": 12, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(5, sum by (project) (increase(opencode_cost_usd_total[24h])))",
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3 } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cost per session",
      "description": "Rising trend = context bloat or weaker cache reuse.",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(opencode_cost_usd_total[1h])) / clamp_min(sum(increase(opencode_sessions_total[1h])), 1)",
          "legendFormat": "$/session",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3 } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cache effectiveness (read/write ratio)",
      "description": "NOT read/(read+write) — that hides magnitude. Healthy long-context: 5x-20x. Below 1 = caching is net-negative.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "job:opencode_cache_ratio:1h",
          "legendFormat": "cache_read / cache_write",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Token mix by type",
      "description": "Stacked. Output > input = runaway agent loop.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(opencode_tokens_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 50,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          }
        }
      }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Model distribution (24h)",
      "description": "Hitting luna or falling back to Anthropic? Sessions + cost per model.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model, provider) (increase(opencode_sessions_total[24h]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "sum by (model, provider) (increase(opencode_cost_usd_total[24h]))",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "sessions",
              "Value #B": "cost_usd"
            },
            "excludeByName": { "Time": true }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 102,
      "panels": [],
      "title": "luna vLLM serving",
      "type": "row"
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "TTFT p50/p95/p99",
      "description": "sum by (le) BEFORE histogram_quantile — otherwise you average quantiles, which is meaningless. p95 uses the precomputed recording rule.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, instance) (rate(vllm:time_to_first_token_seconds_bucket[5m])))",
          "legendFormat": "p50 {{instance}}",
          "refId": "A"
        },
        {
          "expr": "job:vllm_ttft_p95:5m",
          "legendFormat": "p95 {{instance}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, instance) (rate(vllm:time_to_first_token_seconds_bucket[5m])))",
          "legendFormat": "p99 {{instance}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Throughput (output tokens/s)",
      "description": "Real ceiling for AWQ 30B-A3B on 3090Ti+RTX4000 SFF tp=2 ≈ 40-80 tok/s.",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(vllm:generation_tokens_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } },
      "options": {
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 13,
      "type": "gauge",
      "title": "KV cache pressure",
      "description": "Above ~90% vLLM evicts prefix cache, killing cache_read effectiveness.",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "vllm:gpu_cache_usage_perc",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Queue depth",
      "description": "waiting > 0 sustained = saturated; single-user workload should sit at 0.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "waiting",
          "refId": "A"
        },
        {
          "expr": "vllm:num_requests_running",
          "legendFormat": "running",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Request error rate",
      "description": "finished_reason distinguishes stop (good) from length/abort (bad).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(vllm:request_success_total{finished_reason!=\"stop\"}[5m])) / clamp_min(sum(rate(vllm:request_success_total[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 },
      "id": 103,
      "panels": [],
      "title": "luna hardware",
      "type": "row"
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Per-GPU utilization",
      "description": "Asymmetric VRAM (24/20 GiB) but vLLM splits weights evenly — expect 4000 SFF Ada (gpu=1) to bottleneck first.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nvidia_smi_utilization_gpu_ratio * 100",
          "legendFormat": "gpu {{uuid}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 17,
      "type": "bargauge",
      "title": "VRAM headroom per card",
      "description": "Absolute headroom in bytes — % is misleading when cards differ in capacity.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nvidia_smi_memory_total_bytes - nvidia_smi_memory_used_bytes",
          "legendFormat": "gpu {{uuid}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "green", "value": 4294967296 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "GPU temp & power",
      "description": "70W SFF Ada thermal-throttles hard; correlate with TTFT spikes.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nvidia_smi_temperature_gpu",
          "legendFormat": "temp gpu {{uuid}}",
          "refId": "A"
        },
        {
          "expr": "nvidia_smi_power_draw_watts",
          "legendFormat": "power gpu {{gpu}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "axisPlacement": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^temp.*" },
            "properties": [{ "id": "unit", "value": "celsius" }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^power.*" },
            "properties": [
              { "id": "unit", "value": "watt" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 64 },
      "id": 104,
      "panels": [],
      "title": "Cross-cutting",
      "type": "row"
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Cost per ingested note",
      "description": "Uses the precomputed recording rule. clamp_min(rate(...), 1) avoids div-by-zero between runs.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 65 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "job:opencode_cost_per_note:1h",
          "legendFormat": "$/note",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
    },
    {
      "id": 20,
      "type": "table",
      "title": "Cost per 1M tokens by provider (24h)",
      "description": "luna-coder should be ~$0; non-zero = mislabeled exporter or someone hardcoded a per-token rate for the local model.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 65 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (provider) (rate(opencode_cost_usd_total[24h])) / clamp_min(sum by (provider) (rate(opencode_tokens_total[24h])), 1) * 1e6",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value": "$/1M tokens" },
            "excludeByName": { "Time": true }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 2 }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["luna", "ai", "vllm", "opencode"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "luna stack",
  "uid": "luna-stack",
  "version": 1,
  "weekStart": ""
}
